;******************************************************************
;* LPC4337 linker scatter file (running code from internal FLASH) *
;******************************************************************

LR_IROM1 0x1A000000 0x80000
{
   ER_IROM1 0x1A000000 0x80000
   {
      *.o (RESET, +First)
      *(InRoot$$Sections)
      .ANY (+RO)
   }
   
;  RW_IRAM1 0x10080000 0x9000
;  internal sram : 0x20000000/64KB
   RW_IRAM1 0x20000000 0x10000
   { 
      .ANY (+RW +ZI)
   }
   
   RW_IRAM2 0x10000000 0x8000
   { 
      .ANY (+RW +ZI)
   }

;  stack: 0x1008A000/32KB
   ARM_LIB_STACK 0x1008A000 EMPTY -0x8000
   {
   }
   
;  ARM_LIB_HEAP 0x20000000 EMPTY 0x10000
;  heap : 0x10000000/32KB
;  ARM_LIB_HEAP 0x10000000 EMPTY 0x8000
   ARM_LIB_HEAP 0x28000000 EMPTY 0x100000
   {
   }
   
;  dynamic external memory DYCS0(32MB) 
;  sdram : 0x28000000/32MB
;  IRAM에 넣기에 큰 정보를 저장한다
   RW_RAM1 0x28100000 0x1f00000  {
      * (EXT_RAM)
      socket.o (+RW +ZI)
;      wiznet_thread.o (+RW +ZI)	   
      rtx_conf_cm.o (+RW +ZI)
      fs_port_rtx.o (+RW +ZI)
      file_config.o (+RW +ZI)
      meter.o (+RW +ZI)
      iom.o (+RW +ZI)
;	   .ANY (+RW +ZI)      
   }
}
